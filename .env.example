# Shared PostgreSQL configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=floowiapp
POSTGRES_USER=floowiapp
POSTGRES_PASSWORD=floowiapp_password

# API
API_PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://floowiapp:floowiapp_password@localhost:5432/floowiapp
CORS_ORIGINS=http://localhost:5173
JWT_ACCESS_SECRET=change_me_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=flowi/studios

# Web
VITE_API_BASE_URL=http://localhost:3001/api
